SECRET_KEY=replace-with-a-strong-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost
CSRF_TRUSTED_ORIGINS=http://localhost

POSTGRES_DB=pricecompare
POSTGRES_USER=pricecompare
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://pricecompare:change-me@db:5432/pricecompare

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_WORKER_POOL=prefork
CELERY_WORKER_CONCURRENCY=2

# Email verification (signup): link in email points here + /#/verify-email?token=...
FRONTEND_BASE_URL=http://localhost:5173
EMAIL_VERIFICATION_TOKEN_HOURS=48
# For real SMTP, set EMAIL_BACKEND and SMTP settings in Django or use console for dev.
